# Solomons Chamber Configuration
# Copy this to .env (never commit .env)

# Path to your vault
VAULT_PATH=/home/workspace/Solomons-Chamber-Template

# RSS Feeds (comma-separated URLs)
RSS_FEEDS=https://example.com/feed,https://news.ycombinator.com/rss

# Archive threshold (days)
ARCHIVE_DAYS=90

# Obsidian API (optional - for Obsidian Skills integration)
# OBSIDIAN_API_TOKEN=your_token_here